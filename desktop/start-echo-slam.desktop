[Desktop Entry]
Type=Application
Name=Start Echo SLAM
Comment=Launch Echo ESP32 SLAM stack with rosboard and Xbox teleop
Exec=gnome-terminal --title="Echo SLAM" -- bash -lc "ESP32_PORT=/dev/serial/by-path/platform-xhci-hcd.1-usb-0:1:1.0-port0 LIDAR_PORT=/dev/serial/by-path/platform-xhci-hcd.0-usb-0:1:1.0-port0 /home/ahmed/start_echo_slam_esp32.sh; echo; read -p 'Press Enter to close...'"
Icon=utilities-terminal
Terminal=false
Categories=Development;Robotics;
